generator client {
  provider = "prisma-client-js"
}

// Default datasource uses SQLite for easy local setup. Replace with MySQL in production.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  username  String   @unique
  password  String
  email     String?  @unique
  phone     String?
  role      String   @default("STAFF")
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  InventoryHistory InventoryHistory[]
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  category  String?
  volume    String?
  quantity  Int      @default(0)
  importPrice Float
  sellPrice   Float
  bottles300  Int      @default(0)
  bottles500  Int      @default(0)
  bulkLiters  Float    @default(0.0)
  importPrice300 Float @default(0.0)
  sellPrice300   Float @default(0.0)
  importPrice500 Float @default(0.0)
  sellPrice500   Float @default(0.0)
  importPriceBulk Float @default(0.0)
  sellPriceBulk   Float @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  InventoryHistory InventoryHistory[]

  @@index([category])
  @@index([name])
}

model InventoryHistory {
  id         Int      @id @default(autoincrement())
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  action     String
  quantity   Int
  importPrice Float?
  sellPrice   Float?
  note       String?
  user       User?    @relation(fields: [userId], references: [id])
  userId     Int?
  createdAt  DateTime @default(now())

  // New fields for shampoo tracking
  bottles300  Int?
  bottles500  Int?
  bulkLiters  Float?

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  message   String
  response  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Waybill {
  id             Int      @id @default(autoincrement())
  trackingNumber String   @unique
  carrier        String
  status         String
  shipperName    String?
  shipperPhone   String?
  shippingAddress String?
  weight         Float?
  history        String?  // JSON string storing tracking history log
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([trackingNumber])
}

// role and action stored as strings for SQLite compatibility
